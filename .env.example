# Model Configuration
# Provider: "ollama", "openai", "glm", "claude"
MODEL_PROVIDER=ollama
USE_LOCAL_MODEL=true
FALLBACK_TO_CLAUDE=true

# Claude API (only needed if fallback enabled or USE_LOCAL_MODEL=false)
CLAUDE_API_KEY=sk-your-api-key-here

# OpenAI API (for MODEL_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# GLM/z.ai API (for MODEL_PROVIDER=glm)
ZHIPUAI_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4v-flash

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b
MODEL_TIMEOUT_SECONDS=60
MODEL_NUM_PREDICT=128

# Browser Configuration
HEADLESS=false
RECORD_VIDEO=true
SCREENSHOT_DIR=./recordings/screenshots
VIDEO_DIR=./recordings/videos
TRANSCRIPT_DIR=./recordings/transcripts
NAVIGATION_WAIT_UNTIL=domcontentloaded
REUSE_STORAGE_STATE=true
STORAGE_STATE_PATH=./recordings/storage_state.json

# Credentials (create separate entries for each service)
GMAIL_EMAIL=your_email@gmail.com
GMAIL_PASSWORD=your_app_password
EXAMPLE_SITE_USERNAME=username
EXAMPLE_SITE_PASSWORD=password

# Agent Configuration
MAX_RETRIES=3
TIMEOUT_SECONDS=30
VISION_CONFIDENCE_THRESHOLD=0.7
VERBOSE=true
ENABLE_LOGGING=true
ENABLE_LOGIN_POLICIES=true
AUTO_CHECKBOXES=true
PAUSE_ON_CAPTCHA=true
ACTION_STRATEGY=selector_first
